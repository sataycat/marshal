{
  "name": "marshal",
  "version": "0.0.1",
  "description": "Local-first, agent-agnostic coding-agent orchestrator with a build-verify-review loop.",
  "bin": {
    "marshal": "./bin/marshal"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sataycat/marshal.git"
  },
  "homepage": "https://github.com/sataycat/marshal",
  "bugs": "https://github.com/sataycat/marshal/issues",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "pnpm run build && concurrently --kill-others --names daemon,web --prefix-colors blue,green \"node ./bin/marshal start --web-url http://localhost:5173\" \"pnpm --filter marshal-web exec vite --host ::\"",
    "build": "tsc && cp -R src/storage/migrations/. dist/storage/migrations",
    "build:web": "pnpm --filter marshal-web run build",
    "build:all": "pnpm run build && pnpm run build:web",
    "analyze": "pnpm --filter marshal-web run analyze",
    "test": "vitest run",
    "test:web": "pnpm --filter marshal-web run test",
    "test:all": "pnpm run test && pnpm run test:web",
    "check": "tsc --noEmit",
    "check:web": "pnpm --filter marshal-web run check",
    "check:all": "pnpm run check && pnpm run check:web",
    "prepublishOnly": "pnpm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@hono/node-server": "^2.0.8",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "ignore": "^7.0.5",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "shadcn": "^4.13.0",
    "typescript": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
